# Beautify requires these Supabase values in local development and in Vercel.
# You can find them in your Supabase dashboard under Settings -> API.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional: enables the "Use Test Credentials" button on the login screen.
VITE_TEST_LOGIN_EMAIL=test-user@example.com
VITE_TEST_LOGIN_PASSWORD=replace-with-your-test-password
